# ═══════════════════════════════════════════════════
#  LumenAi Backend — Environment Variables Template
#  Copy to .env and fill in your credentials
# ═══════════════════════════════════════════════════

# ─── Application ────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
APP_URL=https://your-frontend.vercel.app

# ─── Database (Neon PostgreSQL recommended) ─────────
DATABASE_URL=jdbc:postgresql://ep-xxx.us-east-2.aws.neon.tech/lumenai_db?sslmode=require
DB_USERNAME=root
DB_PASSWORD=tiger

# ─── JWT ────────────────────────────────────────────
JWT_SECRET=replace-with-a-very-long-random-256-bit-secret-string-minimum-32-characters

# ─── Email (Gmail SMTP) ──────────────────────────────
MAIL_ENABLED=true
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-gmail@gmail.com
# Use a Gmail App Password (not your regular password)
# Go to: Google Account → Security → 2-Step Verification → App Passwords
MAIL_PASSWORD=your-16-char-app-password
MAIL_FROM=noreply@lumenai.app

# ─── OpenAI ─────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Storage ─────────────────────────────────────────
STORAGE_PROVIDER=cloudinary

# Cloudinary (free tier: 25GB, 25k transforms/month)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=123456789012345
CLOUDINARY_API_SECRET=your-api-secret

# AWS S3 (alternative to Cloudinary)
# STORAGE_PROVIDER=s3
# AWS_S3_BUCKET=lumenai-documents
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY=AKIA...
# AWS_SECRET_KEY=...

# ─── Google Books API ────────────────────────────────
# Get free API key at: https://console.cloud.google.com → APIs → Books API
GOOGLE_BOOKS_API_KEY=AIza...
